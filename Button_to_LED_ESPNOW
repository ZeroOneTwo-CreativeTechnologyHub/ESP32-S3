#include <WiFi.h>
#include <esp_now.h>

const int LED_PIN = 1;
const int BUTTON_PIN = 2;

bool lastButtonState = LOW;

// CHANGE THIS to the OTHER board's MAC address
uint8_t peerAddress[] = {0xYY,0xYY,0xYY,0xYY,0xYY,0xYY};

typedef struct struct_message {
  bool buttonPressed;
} struct_message;

struct_message message;

void onReceive(const esp_now_recv_info *info, const uint8_t *incomingData, int len) {
  memcpy(&message, incomingData, sizeof(message));

  if (message.buttonPressed) {
    digitalWrite(LED_PIN, HIGH);
    delay(500);
    digitalWrite(LED_PIN, LOW);
  }
}

void setup() {

  Serial.begin(115200);

  pinMode(LED_PIN, OUTPUT);
  pinMode(BUTTON_PIN, INPUT);

  WiFi.mode(WIFI_STA);

  if (esp_now_init() != ESP_OK) {
    Serial.println("ESP-NOW init failed");
    return;
  }

  esp_now_register_recv_cb(onReceive);

  esp_now_peer_info_t peerInfo = {};
  memcpy(peerInfo.peer_addr, peerAddress, 6);
  peerInfo.channel = 0;
  peerInfo.encrypt = false;

  esp_now_add_peer(&peerInfo);
}

void loop() {

  bool buttonState = digitalRead(BUTTON_PIN);

  if (buttonState == HIGH && lastButtonState == LOW) {

    message.buttonPressed = true;

    esp_now_send(peerAddress, (uint8_t *) &message, sizeof(message));

    delay(50);
  }

  lastButtonState = buttonState;
}
